# ===============================
# Database Configuration
# ===============================

# Formato:
# postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://sigetu:changeme@localhost:5432/sigetu_db

# Para Docker Compose usar el nombre del servicio como host:
# DATABASE_URL=postgresql://sigetu:changeme@db:5432/sigetu_db

# Variables separadas para docker-compose.yml
POSTGRES_USER=sigetu
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sigetu_db


# ===============================
# Seguridad
# ===============================

# Generar con:
# openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here

# Algoritmo JWT (normalmente HS256)
ALGORITHM=HS256


# ===============================
# Configuración de Tokens
# ===============================

# Tiempo de expiración del access token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Tiempo de expiración del refresh token en días
REFRESH_TOKEN_EXPIRE_DAYS=7


# ===============================
# Firebase
# ===============================

# Ruta al archivo de credenciales del SDK de Firebase Admin
# IMPORTANTE: Este archivo NUNCA debe subirse al repositorio
FIREBASE_SERVICE_ACCOUNT_PATH=sigetu-b10c0-firebase-adminsdk-fbsvc-d3c8e11eaf.json

# ===============================
# Configuración de restablecimiento de contraseña
# ===============================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_correo@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=tu_correo@gmail.com
SMTP_FROM_NAME=SIGETU
RESET_PASSWORD_BASE_URL=http://localhost:5173/reset-password